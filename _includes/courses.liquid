{% if site.teachings %}
  <div class="teaching-stats">
    <div class="teaching-stat">
      <span class="teaching-stat__num">{{ site.teachings.size }}</span>
      <span class="teaching-stat__label">Courses</span>
    </div>
    <div class="teaching-stat">
      <span class="teaching-stat__num">5</span>
      <span class="teaching-stat__label">Semesters</span>
    </div>
    <div class="teaching-stat">
      <span class="teaching-stat__num">310<span class="teaching-stat__sub">+</span></span>
      <span class="teaching-stat__label">Students mentored</span>
    </div>
    <div class="teaching-stat">
      <span class="teaching-stat__num">Koç</span>
      <span class="teaching-stat__label">University, İstanbul</span>
    </div>
  </div>

  <div class="courses">
    {% assign courses_by_year = site.teachings | sort: 'year' | reverse | group_by: 'year' %}

    {% for year_group in courses_by_year %}
      <div class="year-header">
        <span class="year-label">{{ year_group.name }}</span>
        <span class="year-line"></span>
      </div>
      <div class="course-list">
        {% assign year_courses = year_group.items | sort: 'term' %}
        {% for course in year_courses %}
          {% assign title_parts = course.title | split: ' - ' %}
          {% assign course_code = title_parts | first | strip %}
          {% assign course_name = title_parts | last | strip %}
          <article class="course-card">
            <div class="course-card__rail">
              <span class="course-card__code">{{ course_code }}</span>
              <span class="course-card__role">Teaching Assistant</span>
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">{{ course_name }}</h3>

              <div class="course-card__meta">
                {% if course.term %}
                  <span class="course-card__chip">
                    <i class="fa-regular fa-calendar"></i>{{ course.term }} {{ course.year }}
                  </span>
                {% endif %}
                {% if course.location %}
                  <span class="course-card__chip">
                    <i class="fa-regular fa-building"></i>{{ course.location }}
                  </span>
                {% endif %}
                {% if course.instructor %}
                  <span class="course-card__chip">
                    <i class="fa-regular fa-user"></i>
                    {% if course.instructor_url %}
                      <a href="{{ course.instructor_url }}" target="_blank" rel="noopener noreferrer">{{ course.instructor }}</a>
                    {% else %}
                      {{ course.instructor }}
                    {% endif %}
                  </span>
                {% endif %}
              </div>

              <div class="course-card__highlights">
                {{ course.content }}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
{% else %}
  <p>No courses available yet.</p>
{% endif %}
